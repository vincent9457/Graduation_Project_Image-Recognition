<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/permissions_fragment">

    <fragment
        android:id="@+id/permissions_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.PermissionsFragment"
        android:label="PermissionsFragment">

        <action
            android:id="@+id/action_permissions_to_home"
            app:destination="@id/home_fragment"
            app:popUpTo="@id/permissions_fragment"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/home_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.HomeFragment"
        android:label="HomeFragment">

        <action
            android:id="@+id/action_home_to_camera"
            app:destination="@id/camera_fragment" />
        <action
            android:id="@+id/action_home_to_stretch"
            app:destination="@id/stretch_fragment" />
        <action
            android:id="@+id/action_home_to_chair_stand"
            app:destination="@id/chair_stand_fragment" />
        <action
            android:id="@+id/action_home_to_walking"
            app:destination="@id/walking_fragment" />
        <action
            android:id="@+id/action_home_to_simulated_sitting"
            app:destination="@id/simulated_sitting_fragment" />
        <action
            android:id="@+id/action_home_to_toe_heel_walking"
            app:destination="@id/toe_heel_walking_fragment" />
        <action
            android:id="@+id/action_home_to_chair_arm_stretch"
            app:destination="@id/chair_arm_stretch_fragment" />
        <action
            android:id="@+id/action_home_to_obstacle_crossing"
            app:destination="@id/obstacle_crossing_fragment" />
        <action
            android:id="@+id/action_home_to_bottle_lift"
            app:destination="@id/bottle_lift_fragment" />
    </fragment>

    <fragment
        android:id="@+id/camera_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.CameraFragment"
        android:label="CameraFragment">

        <action
            android:id="@+id/action_camera_to_permissions"
            app:destination="@id/permissions_fragment"
            app:popUpTo="@id/camera_fragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/stretch_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.StretchFragment"
        android:label="StretchFragment">
    </fragment>

    <fragment
        android:id="@+id/chair_stand_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.ChairStandFragment"
        android:label="ChairStandFragment">
    </fragment>

    <fragment
        android:id="@+id/walking_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.WalkingFragment"
        android:label="WalkingFragment">
    </fragment>

    <fragment
        android:id="@+id/simulated_sitting_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.SimulatedSittingFragment"
        android:label="SimulatedSittingFragment">
    </fragment>

    <fragment
        android:id="@+id/toe_heel_walking_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.ToeHeelWalkingFragment"
        android:label="ToeHeelWalkingFragment">
    </fragment>

    <fragment
        android:id="@+id/chair_arm_stretch_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.ChairArmStretchFragment"
        android:label="ChairArmStretchFragment">
    </fragment>

    <fragment
        android:id="@+id/obstacle_crossing_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.ObstacleCrossingFragment"
        android:label="ObstacleCrossingFragment">
    </fragment>

    <fragment
        android:id="@+id/bottle_lift_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.BottleLiftFragment"
        android:label="BottleLiftFragment">
    </fragment>

    <fragment
        android:id="@+id/gallery_fragment"
        android:name="com.google.mediapipe.examples.poselandmarker.fragment.GalleryFragment"
        android:label="GalleryFragment" />
</navigation>
